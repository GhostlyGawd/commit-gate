{
  "template": {
    "types": ["feat", "fix", "docs", "refactor", "test", "chore", "perf", "build", "ci", "style", "revert"],
    "subjectMaxLen": 72,
    "requireIssueRef": true,
    "issuePrefixes": ["ENG", "OPS"],
    "issueRefRegex": "",
    "trailerFormat": "Refs: {ISSUE}"
  },
  "linear": {
    "enabled": true,
    "action": "comment",
    "commentFormat": "Commit `{SHA}` on `{BRANCH}`: {SUBJECT}",
    "moveToStateName": "",
    "apiUrl": "https://api.linear.app/graphql",
    "timeoutSeconds": 10
  }
}
